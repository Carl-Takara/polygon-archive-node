# ============================================================
# Server Connection
# ============================================================
SERVER_IP=68.168.220.110
SERVER_USER=root
SERVER_HOSTNAME=polygon.fiamma.io

# ============================================================
# Ethereum L1 RPC (Required for Heimdall checkpoint validation)
# Use a reliable Ethereum mainnet RPC endpoint
# ============================================================
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ============================================================
# Heimdall Seeds (Polygon mainnet official seeds)
# ============================================================
HEIMDALL_SEEDS=1500161dd491b67fb1ac81868952be49e2509c9f@52.78.36.216:26656,dd4a3f1750af5765266231b9e8ac56e0bd085735@137.184.229.251:26656,3a9a1de9b539484f7ddc040c7b032eb7b9ef0015@34.87.86.195:26656,7b218ebbfb42084e53f994e4dd7b7a2aec360e52@54.147.31.250:26656,c26558a7ad3ad3087579bd5e1661b2726bc29ef4@54.250.35.145:26656

# ============================================================
# Data Directories (use fast NVMe/SSD mount point)
# ============================================================
ERIGON_DATA_DIR=/data/erigon
HEIMDALL_DATA_DIR=/data/heimdall

# ============================================================
# Snapshot (optional - speeds up initial sync dramatically)
# Set to "true" to download PublicNode snapshot before starting
# ============================================================
USE_SNAPSHOT=true
